# Optional publishable app key for the Pollinations BYOP authorize flow.
VITE_POLLINATIONS_APP_KEY=

# The exact public URL that Pollinations should redirect back to after BYOP auth.
VITE_PUBLIC_APP_URL=http://localhost:5173

# Fallback models used before live model discovery succeeds.
VITE_DEFAULT_TEXT_MODEL=openai
VITE_DEFAULT_IMAGE_MODEL=flux
